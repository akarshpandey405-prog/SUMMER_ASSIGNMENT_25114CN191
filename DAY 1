#include <stdio.h>

int main() {
    long long num;
    int count = 0;

    printf("Enter an integer: ");
    scanf("%lld", &num);

    // Save original number for display, and handle negative numbers
    long long temp = num;
    if (temp < 0) {
        temp = -temp;
    }

    // Handle the special case where the input is exactly 0
    if (temp == 0) {
        count = 1;
    } else {
        // Loop to count digits
        while (temp != 0) {
            temp /= 10; // Removes the last digit
            count++;    // Increments the digit count
        }
    }

    printf("Number of digits in %lld = %d\n", num, count);

    return 0;
}
