#include <stdio.h>

int main() {
    long long n;
    long long sum;

    // Prompt user for input
    printf("Enter a positive integer: ");
    scanf("%lld", &n);

    // Validate input for natural numbers (greater than 0)
    if (n <= 0) {
        printf("Please enter a valid natural number greater than 0.\n");
    } else {
        // Apply the arithmetic progression sum formula
        sum = (n * (n + 1)) / 2;
        printf("The sum of the first %lld natural numbers is: %lld\n", n, sum);
    }

    return 0;
}
